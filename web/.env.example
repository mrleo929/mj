# Supabase：專案 Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# 選用：本機執行 npm run db:apply 套用 migration 時需要（勿 commit）
# Dashboard → Connect（或 Database）→ 複製 Postgres「URI」連線字串（含密碼）
# DATABASE_URI=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
